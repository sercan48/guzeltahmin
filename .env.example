# The Odds API
ODDS_API_KEY=your-odds-api-key

# OpenWeatherMap
OPENWEATHER_API_KEY=your-openweather-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
