# Telegram Bot Token (obtained from BotFather)
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Telegram VIP Channel / Group ID (integer or string with -100 prefix)
VIP_CHANNEL_ID=-100123456789

# Database Connection String (PostgreSQL Asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:mysecretpassword@localhost:5432/vip_automation

# Redis Connection URL
REDIS_URL=redis://localhost:6379/0

# App Settings
ENV=development
DEBUG=True
PORT=8000
INTERNAL_API_TOKEN=secret-token

